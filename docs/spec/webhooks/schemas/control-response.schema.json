{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/control-response.schema.json",
  "title": "Worca Control Webhook Response",
  "description": "Schema for control webhook HTTP response bodies. Control webhooks respond with this structure to send pipeline control commands.",
  "type": "object",
  "properties": {
    "control": {
      "type": "object",
      "description": "Control command to send to the pipeline. Omit or set to null to take no action.",
      "required": ["action"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["approve", "reject", "pause", "resume", "abort", "continue"],
          "description": "Control action to perform. 'continue' is a no-op (default when control is omitted)."
        },
        "reason": {
          "type": "string",
          "description": "Optional human-readable reason for this action (logged by the pipeline)."
        },
        "data": {
          "type": "object",
          "description": "Optional action-specific data.",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "examples": [
    {
      "control": {
        "action": "approve",
        "reason": "Plan looks good, proceeding."
      }
    },
    {
      "control": {
        "action": "reject",
        "reason": "Plan needs more detail on error handling."
      }
    },
    {
      "control": {
        "action": "pause"
      }
    },
    {
      "control": {
        "action": "resume"
      }
    },
    {
      "control": {
        "action": "abort",
        "reason": "Cancelling due to budget overrun."
      }
    },
    {
      "control": {
        "action": "continue"
      }
    }
  ]
}
