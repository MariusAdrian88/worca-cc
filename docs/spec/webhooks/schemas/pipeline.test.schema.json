{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.test.schema.json",
  "title": "Worca Pipeline Test Detail Events",
  "description": "Events covering the TEST stage execution and outcomes (4 events).",
  "oneOf": [
    {
      "title": "pipeline.test.suite_started",
      "description": "Emitted when the TEST stage begins execution.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.test.suite_started"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.test.suite_started.",
          "required": ["stage", "iteration", "trigger"],
          "properties": {
            "stage": {"type": "string", "description": "Always TEST."},
            "iteration": {"type": "integer", "description": "Test iteration number."},
            "trigger": {"type": "string", "description": "What triggered this test run (e.g. initial, fix_attempt)."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.test.suite_passed",
      "description": "Emitted when the test suite passes.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.test.suite_passed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.test.suite_passed.",
          "required": ["iteration"],
          "properties": {
            "iteration": {"type": "integer", "description": "Test iteration number."},
            "coverage_pct": {
              "type": ["number", "null"],
              "description": "Test coverage percentage if reported."
            },
            "proof_artifacts": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Paths to test output artifacts."
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.test.suite_failed",
      "description": "Emitted when the test suite fails.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.test.suite_failed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.test.suite_failed.",
          "required": ["iteration", "failure_count", "failures"],
          "properties": {
            "iteration": {"type": "integer", "description": "Test iteration number."},
            "failure_count": {"type": "integer", "description": "Number of failing tests."},
            "failures": {
              "type": "array",
              "maxItems": 10,
              "description": "Up to 10 failures. Capped at 10 to prevent large payloads.",
              "items": {
                "type": "object",
                "properties": {
                  "test": {"type": "string"},
                  "error": {"type": "string"},
                  "file": {"type": "string"}
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.test.fix_attempt",
      "description": "Emitted before looping back to IMPLEMENT after a test failure.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.test.fix_attempt"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.test.fix_attempt.",
          "required": ["attempt", "limit", "failures_summary"],
          "properties": {
            "attempt": {"type": "integer", "description": "Fix attempt number (1-based)."},
            "limit": {"type": "integer", "description": "Maximum fix attempts configured."},
            "failures_summary": {"type": "string", "description": "Brief summary of the failures driving this attempt."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
