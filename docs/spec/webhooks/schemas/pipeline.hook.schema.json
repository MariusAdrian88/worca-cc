{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.hook.schema.json",
  "title": "Worca Pipeline Hook & Governance Events",
  "description": "Events from pipeline hook processes capturing governance enforcement actions (3 events).",
  "oneOf": [
    {
      "title": "pipeline.hook.blocked",
      "description": "Emitted when a governance guard blocks a tool call.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.hook.blocked"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.hook.blocked.",
          "required": ["agent", "tool", "reason"],
          "properties": {
            "agent": {"type": "string", "description": "Agent that attempted the blocked action (e.g. implementer)."},
            "tool": {"type": "string", "description": "Tool that was blocked (e.g. Bash)."},
            "reason": {"type": "string", "description": "Human-readable reason for blocking."},
            "rule": {"type": "string", "description": "Specific governance rule that triggered the block."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.hook.test_gate",
      "description": "Emitted when the test gate triggers (consecutive pytest failures).",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.hook.test_gate"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.hook.test_gate.",
          "required": ["agent", "strike", "action"],
          "properties": {
            "agent": {"type": "string", "description": "Agent that triggered the gate."},
            "strike": {"type": "integer", "description": "Current consecutive failure count (1 or 2)."},
            "action": {
              "type": "string",
              "enum": ["warn", "block"],
              "description": "warn (first strike) or block (second strike)."
            },
            "command": {"type": "string", "description": "The pytest command that failed."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.hook.dispatch_blocked",
      "description": "Emitted when a subagent dispatch is denied by governance rules.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.hook.dispatch_blocked"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.hook.dispatch_blocked.",
          "required": ["agent", "subagent_type"],
          "properties": {
            "agent": {"type": "string", "description": "Agent that attempted the dispatch."},
            "subagent_type": {"type": "string", "description": "The subagent type that was blocked."},
            "reason": {"type": "string", "description": "Reason for blocking."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
