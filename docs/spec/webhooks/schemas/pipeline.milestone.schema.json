{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.milestone.schema.json",
  "title": "Worca Pipeline Milestone Events",
  "description": "Events for milestone gate evaluations (1 event).",
  "oneOf": [
    {
      "title": "pipeline.milestone.set",
      "description": "Emitted when a milestone gate is evaluated (e.g. plan approval).",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.milestone.set"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.milestone.set.",
          "required": ["milestone", "value", "stage"],
          "properties": {
            "milestone": {"type": "string", "description": "Milestone name (e.g. plan_approved)."},
            "value": {
              "type": ["boolean", "null"],
              "description": "true if approved, false if rejected, null if awaiting external approval."
            },
            "stage": {"type": "string", "description": "Stage that set this milestone."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
