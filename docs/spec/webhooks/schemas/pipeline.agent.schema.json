{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.agent.schema.json",
  "title": "Worca Pipeline Agent Telemetry Events",
  "description": "Real-time agent activity events from inside the agent subprocess stream (5 events).",
  "oneOf": [
    {
      "title": "pipeline.agent.spawned",
      "description": "Emitted when an agent subprocess starts.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.agent.spawned"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.agent.spawned.",
          "required": ["stage", "iteration", "agent", "model", "max_turns"],
          "properties": {
            "stage": {"type": "string", "description": "Stage that launched this agent."},
            "iteration": {"type": "integer", "description": "Stage iteration number."},
            "agent": {"type": "string", "description": "Agent template name."},
            "model": {"type": "string", "description": "Claude model ID."},
            "pid": {"type": "integer", "description": "Process ID of the Claude subprocess."},
            "max_turns": {"type": "integer", "description": "Maximum turns for this invocation."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.agent.tool_use",
      "description": "Emitted each time the agent calls a tool.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.agent.tool_use"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.agent.tool_use.",
          "required": ["stage", "iteration", "tool", "tool_input_summary", "turn"],
          "properties": {
            "stage": {"type": "string"},
            "iteration": {"type": "integer"},
            "tool": {"type": "string", "description": "Tool name (e.g. Read, Bash, Write)."},
            "tool_input_summary": {"type": "string", "description": "Abbreviated tool input. Never contains file contents."},
            "turn": {"type": "integer", "description": "Current agent turn number."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.agent.tool_result",
      "description": "Emitted when a tool call returns a result.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.agent.tool_result"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.agent.tool_result.",
          "required": ["stage", "iteration", "tool", "is_error", "turn"],
          "properties": {
            "stage": {"type": "string"},
            "iteration": {"type": "integer"},
            "tool": {"type": "string"},
            "is_error": {"type": "boolean", "description": "true if the tool returned an error result."},
            "turn": {"type": "integer"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.agent.text",
      "description": "Emitted when the agent outputs text. Contains length only, not the text itself.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.agent.text"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.agent.text.",
          "required": ["stage", "iteration", "text_length", "turn"],
          "properties": {
            "stage": {"type": "string"},
            "iteration": {"type": "integer"},
            "text_length": {"type": "integer", "description": "Number of characters in the text block."},
            "turn": {"type": "integer"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.agent.completed",
      "description": "Emitted when the agent subprocess exits.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.agent.completed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.agent.completed.",
          "required": ["stage", "iteration", "turns", "cost_usd", "duration_ms", "exit_code"],
          "properties": {
            "stage": {"type": "string"},
            "iteration": {"type": "integer"},
            "turns": {"type": "integer", "description": "Total turns used."},
            "cost_usd": {"type": "number", "description": "Total cost for this invocation in USD."},
            "duration_ms": {"type": "integer", "description": "Subprocess duration in milliseconds."},
            "exit_code": {"type": "integer", "description": "Subprocess exit code (0 = success)."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
