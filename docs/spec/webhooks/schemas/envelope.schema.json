{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/envelope.schema.json",
  "title": "Worca Webhook Event Envelope",
  "description": "Common envelope structure for all Worca pipeline events.",
  "type": "object",
  "required": ["schema_version", "event_id", "event_type", "timestamp", "run_id", "pipeline", "payload"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1",
      "description": "Schema version. Currently always '1'. Bumped only on breaking changes."
    },
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique UUID4 for this event. Use for idempotency and deduplication."
    },
    "event_type": {
      "type": "string",
      "description": "Dotted event name, e.g. 'pipeline.run.started'."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when the event was emitted."
    },
    "run_id": {
      "type": "string",
      "description": "Pipeline run identifier in YYYYMMDD-HHMMSS format."
    },
    "pipeline": {
      "type": "object",
      "description": "Pipeline context for this run.",
      "required": ["branch", "work_request"],
      "properties": {
        "branch": {
          "type": "string",
          "description": "Git branch name for this run."
        },
        "work_request": {
          "type": "object",
          "description": "Work request details.",
          "properties": {
            "title": {
              "type": "string",
              "description": "Human-readable work request title."
            },
            "source_ref": {
              "type": "string",
              "description": "Source reference, e.g. 'gh:issue:42' or 'bead:worca-cc-abc'."
            },
            "priority": {
              "type": "string",
              "description": "Priority string, e.g. 'P2'."
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "payload": {
      "type": "object",
      "description": "Event-specific payload. Fields vary by event_type.",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
