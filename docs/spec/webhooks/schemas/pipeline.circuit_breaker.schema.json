{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.circuit_breaker.schema.json",
  "title": "Worca Pipeline Circuit Breaker Events",
  "description": "Events from the circuit breaker that monitors consecutive failures (4 events).",
  "oneOf": [
    {
      "title": "pipeline.circuit_breaker.failure_recorded",
      "description": "Emitted when a failure is recorded by the circuit breaker.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.circuit_breaker.failure_recorded"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.circuit_breaker.failure_recorded.",
          "required": ["stage", "error", "category", "retriable", "consecutive_failures"],
          "properties": {
            "stage": {"type": "string", "description": "Stage where the failure occurred."},
            "error": {"type": "string", "description": "Error message."},
            "category": {"type": "string", "description": "Error category (e.g. transient, persistent, fatal)."},
            "retriable": {"type": "boolean", "description": "Whether the error is considered retriable."},
            "consecutive_failures": {"type": "integer", "description": "Count of consecutive failures after recording this one."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.circuit_breaker.retry",
      "description": "Emitted when the circuit breaker schedules a retry with backoff.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.circuit_breaker.retry"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.circuit_breaker.retry.",
          "required": ["stage", "attempt", "delay_seconds", "consecutive_failures"],
          "properties": {
            "stage": {"type": "string", "description": "Stage being retried."},
            "attempt": {"type": "integer", "description": "Retry attempt number."},
            "delay_seconds": {"type": "number", "description": "Seconds to wait before the retry (exponential backoff)."},
            "consecutive_failures": {"type": "integer", "description": "Current consecutive failure count."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.circuit_breaker.tripped",
      "description": "Emitted just before the pipeline halts due to too many failures.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.circuit_breaker.tripped"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.circuit_breaker.tripped.",
          "required": ["reason", "consecutive_failures", "category"],
          "properties": {
            "reason": {"type": "string", "description": "Human-readable reason for tripping."},
            "consecutive_failures": {"type": "integer", "description": "Failure count that triggered the trip."},
            "category": {"type": "string", "description": "Error category."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.circuit_breaker.reset",
      "description": "Emitted when a successful stage execution resets the failure counter.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.circuit_breaker.reset"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.circuit_breaker.reset.",
          "required": ["stage", "previous_consecutive_failures"],
          "properties": {
            "stage": {"type": "string", "description": "Stage that succeeded."},
            "previous_consecutive_failures": {"type": "integer", "description": "Failure count before reset."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
