{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.preflight.schema.json",
  "title": "Worca Pipeline Preflight Events",
  "description": "Events from the PREFLIGHT stage that runs pre-pipeline checks (2 events).",
  "oneOf": [
    {
      "title": "pipeline.preflight.completed",
      "description": "Emitted when preflight checks finish running.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.preflight.completed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.preflight.completed.",
          "required": ["checks", "all_passed"],
          "properties": {
            "checks": {
              "type": "array",
              "description": "Array of check results.",
              "items": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "status": {
                    "type": "string",
                    "enum": ["pass", "fail", "warn"]
                  },
                  "message": {"type": "string"}
                },
                "additionalProperties": true
              }
            },
            "all_passed": {"type": "boolean", "description": "true if all checks passed."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.preflight.skipped",
      "description": "Emitted when preflight is bypassed (e.g. via --skip-preflight flag).",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.preflight.skipped"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.preflight.skipped.",
          "required": ["reason"],
          "properties": {
            "reason": {"type": "string", "description": "Why preflight was skipped (e.g. --skip-preflight flag)."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
