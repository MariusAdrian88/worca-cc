{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.stage.schema.json",
  "title": "Worca Pipeline Stage Events",
  "description": "Events emitted for every stage iteration lifecycle (4 events).",
  "oneOf": [
    {
      "title": "pipeline.stage.started",
      "description": "Emitted at the beginning of each stage iteration.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.stage.started"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.stage.started.",
          "required": ["stage", "iteration", "agent", "model", "trigger", "max_turns"],
          "properties": {
            "stage": {"type": "string", "description": "Stage name (e.g. PLAN, IMPLEMENT, TEST)."},
            "iteration": {"type": "integer", "description": "Iteration number within this stage (1-based)."},
            "agent": {"type": "string", "description": "Agent template name (e.g. planner, implementer)."},
            "model": {"type": "string", "description": "Claude model ID being used."},
            "trigger": {"type": "string", "description": "What triggered this stage (e.g. initial, test_failure)."},
            "max_turns": {"type": "integer", "description": "Maximum turns configured for this agent invocation."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.stage.completed",
      "description": "Emitted when a stage iteration finishes successfully.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.stage.completed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.stage.completed.",
          "required": ["stage", "iteration", "duration_ms", "cost_usd", "turns", "outcome"],
          "properties": {
            "stage": {"type": "string"},
            "iteration": {"type": "integer"},
            "duration_ms": {"type": "integer", "description": "Stage duration in milliseconds."},
            "cost_usd": {"type": "number", "description": "Cost of this stage iteration in USD."},
            "turns": {"type": "integer", "description": "Number of agent turns used."},
            "outcome": {"type": "string", "description": "Stage outcome (e.g. success, passed, approved)."},
            "token_usage": {
              "type": "object",
              "description": "Token usage breakdown.",
              "properties": {
                "input_tokens": {"type": "integer"},
                "output_tokens": {"type": "integer"}
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.stage.failed",
      "description": "Emitted when a stage iteration terminates with an error.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.stage.failed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.stage.failed.",
          "required": ["stage", "iteration", "error", "error_type", "elapsed_ms"],
          "properties": {
            "stage": {"type": "string"},
            "iteration": {"type": "integer"},
            "error": {"type": "string", "description": "Error message."},
            "error_type": {"type": "string", "description": "Exception class name."},
            "elapsed_ms": {"type": "integer", "description": "Elapsed time when failure occurred."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.stage.interrupted",
      "description": "Emitted when a stage is interrupted by a signal mid-execution.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.stage.interrupted"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.stage.interrupted.",
          "required": ["stage", "iteration", "elapsed_ms"],
          "properties": {
            "stage": {"type": "string"},
            "iteration": {"type": "integer"},
            "elapsed_ms": {"type": "integer", "description": "Elapsed time when interrupted."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
