{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.bead.schema.json",
  "title": "Worca Pipeline Bead Lifecycle Events",
  "description": "Events tracking individual work items (beads) through COORDINATE and IMPLEMENT stages (6 events).",
  "oneOf": [
    {
      "title": "pipeline.bead.created",
      "description": "Emitted when a new bead is created during the COORDINATE stage.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.bead.created"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.bead.created.",
          "required": ["bead_id", "title"],
          "properties": {
            "bead_id": {"type": "string", "description": "Bead identifier (e.g. worca-cc-abc)."},
            "title": {"type": "string", "description": "Bead title."},
            "run_label": {"type": "string", "description": "Run label applied to link this bead to the run."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.bead.assigned",
      "description": "Emitted when a bead is picked up by an implementer.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.bead.assigned"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.bead.assigned.",
          "required": ["bead_id", "title", "iteration"],
          "properties": {
            "bead_id": {"type": "string"},
            "title": {"type": "string"},
            "iteration": {"type": "integer", "description": "IMPLEMENT stage iteration number."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.bead.completed",
      "description": "Emitted when a bead is successfully closed.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.bead.completed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.bead.completed.",
          "required": ["bead_id", "reason"],
          "properties": {
            "bead_id": {"type": "string"},
            "reason": {"type": "string", "description": "Completion reason (e.g. implemented)."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.bead.failed",
      "description": "Emitted when a bead could not be closed.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.bead.failed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.bead.failed.",
          "required": ["bead_id", "error"],
          "properties": {
            "bead_id": {"type": "string"},
            "error": {"type": "string", "description": "Error message explaining why the bead could not be closed."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.bead.labeled",
      "description": "Emitted when a run label is applied to a set of beads.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.bead.labeled"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.bead.labeled.",
          "required": ["bead_ids", "label"],
          "properties": {
            "bead_ids": {
              "type": "array",
              "items": {"type": "string"},
              "description": "IDs of beads that were labeled."
            },
            "label": {"type": "string", "description": "Label applied (e.g. run:20260309-143200)."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.bead.next",
      "description": "Emitted when more beads are available and the pipeline loops back to IMPLEMENT.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.bead.next"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.bead.next.",
          "required": ["next_bead_id", "bead_iteration"],
          "properties": {
            "next_bead_id": {"type": "string", "description": "ID of the next bead to be implemented."},
            "bead_iteration": {"type": "integer", "description": "Bead loop iteration count."},
            "max_beads": {"type": "integer", "description": "Maximum beads configured for this run."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
