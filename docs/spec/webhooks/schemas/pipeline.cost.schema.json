{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.cost.schema.json",
  "title": "Worca Pipeline Cost & Token Events",
  "description": "Events tracking token usage and cost across pipeline stages (3 events).",
  "oneOf": [
    {
      "title": "pipeline.cost.stage_total",
      "description": "Emitted after each stage completes with token usage data.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.cost.stage_total"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.cost.stage_total.",
          "required": ["stage", "iteration", "cost_usd", "input_tokens", "output_tokens", "model"],
          "properties": {
            "stage": {"type": "string", "description": "Stage name."},
            "iteration": {"type": "integer", "description": "Stage iteration."},
            "cost_usd": {"type": "number", "description": "Cost for this stage iteration in USD."},
            "input_tokens": {"type": "integer", "description": "Input tokens consumed."},
            "output_tokens": {"type": "integer", "description": "Output tokens generated."},
            "model": {"type": "string", "description": "Model used for this stage."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.cost.running_total",
      "description": "Emitted after each stage with cumulative run totals.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.cost.running_total"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.cost.running_total.",
          "required": ["total_cost_usd", "total_input_tokens", "total_output_tokens"],
          "properties": {
            "total_cost_usd": {"type": "number", "description": "Cumulative cost across all stages so far."},
            "total_input_tokens": {"type": "integer", "description": "Cumulative input tokens."},
            "total_output_tokens": {"type": "integer", "description": "Cumulative output tokens."},
            "by_stage": {
              "type": "object",
              "description": "Per-stage cost breakdown.",
              "additionalProperties": true
            },
            "by_model": {
              "type": "object",
              "description": "Per-model cost breakdown.",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.cost.budget_warning",
      "description": "Emitted when running cost exceeds the configured budget threshold.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.cost.budget_warning"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.cost.budget_warning.",
          "required": ["total_cost_usd", "budget_usd", "pct_used"],
          "properties": {
            "total_cost_usd": {"type": "number", "description": "Current total cost."},
            "budget_usd": {"type": "number", "description": "Configured budget limit."},
            "pct_used": {"type": "number", "description": "Percentage of budget used (e.g. 80.5)."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
