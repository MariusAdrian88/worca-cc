{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.run.schema.json",
  "title": "Worca Pipeline Run Events",
  "description": "Events covering the overall pipeline run lifecycle (5 events).",
  "oneOf": [
    {
      "title": "pipeline.run.started",
      "description": "Emitted when the pipeline begins execution, after initialization.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.run.started"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.run.started.",
          "required": ["resume", "started_at"],
          "properties": {
            "resume": {
              "type": "boolean",
              "description": "true if resuming from a prior checkpoint, false for a fresh start."
            },
            "started_at": {
              "type": "string",
              "format": "date-time",
              "description": "When this run was initialized."
            },
            "plan_file": {
              "type": ["string", "null"],
              "description": "Path to plan file if provided as input, otherwise null."
            },
            "settings_snapshot": {
              "type": "object",
              "description": "Snapshot of relevant worca settings for this run.",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.run.completed",
      "description": "Emitted when the pipeline finishes successfully (all stages completed).",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.run.completed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.run.completed.",
          "required": ["duration_ms", "total_cost_usd", "total_turns", "total_tokens", "stages_completed"],
          "properties": {
            "duration_ms": {
              "type": "integer",
              "description": "Total run duration in milliseconds."
            },
            "total_cost_usd": {
              "type": "number",
              "description": "Total cost of the run in USD."
            },
            "total_turns": {
              "type": "integer",
              "description": "Total agent turns across all stages."
            },
            "total_tokens": {
              "type": "integer",
              "description": "Total tokens consumed across all stages."
            },
            "stages_completed": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Ordered list of stage names that completed successfully."
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.run.failed",
      "description": "Emitted when the pipeline terminates with an unrecoverable error.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.run.failed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.run.failed.",
          "required": ["error", "failed_stage", "error_type"],
          "properties": {
            "error": {
              "type": "string",
              "description": "Human-readable error message."
            },
            "failed_stage": {
              "type": ["string", "null"],
              "description": "Stage name where failure occurred, or null if pre-stage."
            },
            "error_type": {
              "type": "string",
              "description": "Python exception class name (e.g. PipelineError, LoopExhaustedError)."
            },
            "loop_counters": {
              "type": "object",
              "description": "Current loop iteration counts at time of failure.",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.run.interrupted",
      "description": "Emitted when the pipeline is interrupted by a signal (SIGTERM/SIGINT) or user abort.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.run.interrupted"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.run.interrupted.",
          "required": ["interrupted_stage", "elapsed_ms"],
          "properties": {
            "interrupted_stage": {
              "type": "string",
              "description": "Stage name that was active when interrupted."
            },
            "elapsed_ms": {
              "type": "integer",
              "description": "Elapsed run time in milliseconds at interruption."
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.run.resumed",
      "description": "Emitted when the pipeline detects a prior checkpoint and resumes from it.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.run.resumed"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.run.resumed.",
          "required": ["resume_stage", "previous_stages_completed"],
          "properties": {
            "resume_stage": {
              "type": "string",
              "description": "The stage the pipeline is resuming from."
            },
            "previous_stages_completed": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Stages that were already completed before resumption."
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
