{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.git.schema.json",
  "title": "Worca Pipeline Git Operation Events",
  "description": "Events covering git operations performed by the pipeline (4 events).",
  "oneOf": [
    {
      "title": "pipeline.git.branch_created",
      "description": "Emitted when a new git branch is created for this pipeline run.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.git.branch_created"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.git.branch_created.",
          "required": ["branch"],
          "properties": {
            "branch": {"type": "string", "description": "Name of the branch created (e.g. worca/w-042-add-auth)."},
            "base_ref": {"type": "string", "description": "Base ref the branch was created from (e.g. main)."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.git.commit",
      "description": "Emitted when a commit is made (always during the GUARDIAN stage).",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.git.commit"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.git.commit.",
          "required": ["stage", "commit_hash", "message_summary"],
          "properties": {
            "stage": {"type": "string", "description": "Stage during which the commit occurred (always GUARDIAN)."},
            "commit_hash": {"type": "string", "description": "Short commit hash (7 characters)."},
            "message_summary": {"type": "string", "description": "First line of the commit message (subject)."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.git.pr_created",
      "description": "Emitted when a pull request is created.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.git.pr_created"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.git.pr_created.",
          "required": ["pr_url", "pr_number", "title"],
          "properties": {
            "pr_url": {"type": "string", "description": "Full URL of the created pull request."},
            "pr_number": {"type": "integer", "description": "PR number."},
            "title": {"type": "string", "description": "PR title."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.git.pr_merged",
      "description": "Emitted when a pull request is merged.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.git.pr_merged"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.git.pr_merged.",
          "required": ["pr_url", "pr_number"],
          "properties": {
            "pr_url": {"type": "string", "description": "URL of the merged pull request."},
            "pr_number": {"type": "integer", "description": "PR number."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
