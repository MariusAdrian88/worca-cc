{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.loop.schema.json",
  "title": "Worca Pipeline Loop Events",
  "description": "Events tracking pipeline loop-back transitions and exhaustion (2 events).",
  "oneOf": [
    {
      "title": "pipeline.loop.triggered",
      "description": "Emitted when the pipeline loops back (test failure → implement, etc.).",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.loop.triggered"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.loop.triggered.",
          "required": ["loop_key", "iteration", "from_stage", "to_stage", "trigger"],
          "properties": {
            "loop_key": {"type": "string", "description": "Loop identifier (e.g. implement_test, pr_changes)."},
            "iteration": {"type": "integer", "description": "Current loop iteration."},
            "from_stage": {"type": "string", "description": "Stage looping from."},
            "to_stage": {"type": "string", "description": "Stage looping to."},
            "trigger": {"type": "string", "description": "What caused the loop (e.g. test_failure, review_request_changes)."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.loop.exhausted",
      "description": "Emitted when a loop reaches its configured maximum without completing.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.loop.exhausted"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.loop.exhausted.",
          "required": ["loop_key", "iteration", "limit"],
          "properties": {
            "loop_key": {"type": "string", "description": "Loop identifier."},
            "iteration": {"type": "integer", "description": "Final iteration count reached."},
            "limit": {"type": "integer", "description": "Configured maximum."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
