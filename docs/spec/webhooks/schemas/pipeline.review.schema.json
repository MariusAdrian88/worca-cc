{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca.dev/schemas/webhooks/pipeline.review.schema.json",
  "title": "Worca Pipeline Review Detail Events",
  "description": "Events covering the REVIEW stage execution and outcomes (3 events).",
  "oneOf": [
    {
      "title": "pipeline.review.started",
      "description": "Emitted when the REVIEW stage begins.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.review.started"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.review.started.",
          "required": ["iteration"],
          "properties": {
            "iteration": {"type": "integer", "description": "Review iteration number."},
            "files_under_review": {
              "type": "array",
              "items": {"type": "string"},
              "description": "File paths being reviewed, if determinable."
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.review.verdict",
      "description": "Emitted when the guardian issues a review verdict.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.review.verdict"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.review.verdict.",
          "required": ["outcome", "issue_count", "critical_count"],
          "properties": {
            "outcome": {
              "type": "string",
              "enum": ["approve", "request_changes", "reject", "restart_planning"],
              "description": "Review outcome."
            },
            "issue_count": {"type": "integer", "description": "Total number of issues found."},
            "critical_count": {"type": "integer", "description": "Number of critical/blocking issues."}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "title": "pipeline.review.fix_attempt",
      "description": "Emitted before looping back to IMPLEMENT after a review requesting changes.",
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {
          "const": "pipeline.review.fix_attempt"
        },
        "payload": {
          "type": "object",
          "description": "Payload for pipeline.review.fix_attempt.",
          "required": ["attempt", "limit"],
          "properties": {
            "attempt": {"type": "integer", "description": "Fix attempt number (1-based)."},
            "limit": {"type": "integer", "description": "Maximum fix attempts configured."},
            "critical_issues": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Descriptions of critical issues from the review."
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
